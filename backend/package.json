  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.1",
